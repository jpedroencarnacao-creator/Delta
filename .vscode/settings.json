{
    "C_Cpp.intelliSenseEngine": "disabled",
    "python.analysis.extraPaths": [
        "${workspaceFolder}/Python_CODE",
        "${workspaceFolder}/Python_CODE/Interface de controlo ver_PI4B",
        "${workspaceFolder}/Python_CODE/Interface de controlo ver_windows"
    ],
    "python.terminal.activateEnvironment": true,
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.diagnosticSeverityOverrides": {
        "reportMissingTypeStubs": "none"
    },
    "code-runner.executorMap": {
        "python": "cd $workspaceRoot && LANG=C.UTF-8 LC_ALL=C.UTF-8 .venv/bin/python -u $fullFileName"
    },
    "code-runner.runInTerminal": false,
    "terminal.integrated.env.linux": {
        "LANG": "C.UTF-8",
        "LC_ALL": "C.UTF-8"
    },
    "files.associations": {
        "*.text": "plaintext"
    }
}
